const tg=window.Telegram?.WebApp;if(tg){tg.ready();tg.expand()}const user=tg?.initDataUnsafe?.user||{id:5255297864,username:"test"};let catalog=[],settings={},cart=[];const $=s=>document.querySelector(s);$("#username").value=user.username?`@${user.username}`:"";$("#ageBtn").onclick=async()=>{$("#hero").classList.add("hidden");$("#shop").classList.remove("hidden");await load()};$("#cartBtn").onclick=()=>{$("#shop").classList.add("hidden");$("#cartScreen").classList.remove("hidden");renderCart()};$("#backBtn").onclick=()=>{$("#cartScreen").classList.add("hidden");$("#shop").classList.remove("hidden")};$("#closeBtn").onclick=()=>tg?tg.close():null;$("#delivery").onchange=()=>{if($("#delivery").value==="pickup"){$("#city").value="Величка";$("#city").readOnly=true}else{$("#city").readOnly=false;if($("#city").value==="Величка")$("#city").value=""}renderCart()};async function load(){catalog=(await fetch("/api/catalog").then(r=>r.json())).catalog;settings=await fetch("/api/settings").then(r=>r.json());$("#rules").textContent=settings.rules_text;$("#paymentText").textContent=settings.payment_text;renderCatalog();renderCount()}function esc(v){return String(v).replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;")}function renderCatalog(){const el=$("#catalog");el.innerHTML="";catalog.forEach(p=>{let f=p.flavors[0];let card=document.createElement("article");card.className="product";card.innerHTML=`<div class="product-head"><div><h3>${esc(p.name)}</h3><p>${esc(p.category)} • ${esc(p.strength)}</p></div><div class="price">${p.price} zł</div></div><p>${esc(p.description)}</p><div class="flavors">${p.flavors.map((x,i)=>`<button class="flavor ${i===0?"active":""}" data-id="${x.id}" data-name="${esc(x.name)}">${esc(x.name)}</button>`).join("")}</div><button class="primary add">Добавить</button>`;card.querySelectorAll(".flavor").forEach(b=>b.onclick=()=>{card.querySelectorAll(".flavor").forEach(x=>x.classList.remove("active"));b.classList.add("active");f={id:+b.dataset.id,name:b.dataset.name}});card.querySelector(".add").onclick=()=>{let old=cart.find(x=>x.product_id===p.id&&x.flavor_id===f.id);old?old.qty++:cart.push({product_id:p.id,flavor_id:f.id,name:p.name,flavor:f.name,price:p.price,qty:1});renderCount();tg?.HapticFeedback?.notificationOccurred("success")};el.appendChild(card)})}function renderCount(){$("#cartCount").textContent=cart.reduce((s,x)=>s+x.qty,0)}function fee(){return $("#delivery").value==="city_delivery"?15:$("#delivery").value==="other_city_delivery"?20:0}function total(){return cart.reduce((s,x)=>s+x.price*x.qty,0)+fee()}function renderCart(){let el=$("#cartItems");el.innerHTML=cart.length?"":`<p class="notice">Корзина пустая.</p>`;cart.forEach(item=>{let d=document.createElement("div");d.className="cart-item";d.innerHTML=`<h3>${esc(item.name)}</h3><p>${esc(item.flavor)} • ${item.price} zł × ${item.qty}</p><button class="ghost minus">-</button> <button class="ghost plus">+</button> <button class="danger remove">Удалить</button>`;d.querySelector(".minus").onclick=()=>{item.qty--;if(item.qty<=0)cart=cart.filter(x=>x!==item);renderCart();renderCount()};d.querySelector(".plus").onclick=()=>{item.qty++;renderCart();renderCount()};d.querySelector(".remove").onclick=()=>{cart=cart.filter(x=>x!==item);renderCart();renderCount()};el.appendChild(d)});$("#total").textContent=`${total()} zł`}$("#orderForm").onsubmit=async e=>{e.preventDefault();if(!cart.length)return alert("Корзина пустая");let f=new FormData(e.target);let payload={user_id:user.id,username:user.username||"",name:f.get("name"),phone:f.get("phone"),delivery_type:f.get("delivery_type"),city:f.get("city"),address:f.get("address")||"",comment:f.get("comment")||"",items:cart,total:total()};let res=await fetch("/api/order",{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload)}).then(r=>r.json());if(!res.ok)return alert("Ошибка");$("#cartScreen").classList.add("hidden");$("#payScreen").classList.remove("hidden");$("#orderId").textContent=res.order_id;$("#payCommand").textContent=`/pay ${res.order_id}`;cart=[];renderCount()};
